# Full URL to the EnviGuide login page (including protocol).
DQR_URL=https://enviguide.example.com/login

# Credentials used by the automation. Never commit the real .env file.
DQR_USER=your-email@example.com
DQR_PASS=your-password

# Optional: override the auto-detected post-login landing URL check.
# DQR_HOME_URL_SUBSTRING=/dashboard
